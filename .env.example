# =============================================================================
# NeuroLog — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# See README.md § Quick Start for setup instructions.
# =============================================================================

# =============================================================================
# Model Configuration
# =============================================================================
# LiteLLM model ID — determines which LLM extracts Datalog facts.
# The prefix selects the API key automatically (anthropic/ → ANTHROPIC_API_KEY).
# Recommended: Claude Sonnet for cost/quality balance, Opus for max accuracy.
#
# Examples:
#   anthropic/claude-sonnet-4-6
#   anthropic/claude-opus-4-6
#   openai/gpt-4o
MODEL_NAME="anthropic/claude-sonnet-4-6"

# Cost optimization: sub-agents that don't need deep reasoning (extraction
# orchestration, CVE lookup) use this model. Defaults to MODEL_NAME if unset.
# Recommendation: use Sonnet here even if MODEL_NAME is Opus — saves ~10x
# on routing/extraction calls while keeping Opus for analysis & interpretation.
# LITE_MODEL_NAME="anthropic/claude-sonnet-4-6"

# =============================================================================
# API Keys — set the key(s) for your chosen provider
# =============================================================================
# At minimum, set the key matching your MODEL_NAME prefix.

ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""

# =============================================================================
# Optional: Binary Ninja MCP Bridge (for binary analysis mode only)
# =============================================================================
# Not required for source-code analysis. Only needed if using the binary
# analysis sibling project (bin_datalog) with Binary Ninja.
# MCP_PYTHON_PATH="/path/to/binary_ninja_mcp/.venv/bin/python3"
# MCP_BRIDGE_PATH="/path/to/binary_ninja_mcp/bridge/binja_mcp_bridge.py"
# BN_PYTHON_PATH="/path/to/binaryninja/python"
